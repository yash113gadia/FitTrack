{
  "expo": {
    "name": "FitTrack",
    "slug": "fittrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#007bff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/your-project-id"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.fittrack",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "FitTrack needs camera access to scan barcodes and recognize food.",
        "NSPhotoLibraryUsageDescription": "FitTrack needs photo library access to let you choose food images.",
        "NSUserTrackingUsageDescription": "FitTrack uses tracking to provide personalized nutrition insights."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#007bff"
      },
      "package": "com.yourcompany.fittrack",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FitTrack to access your camera for scanning food."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FitTrack to access your photos for food logging."
        }
      ]
    ],
    "extra": {
      "appEnv": "production",
      "geminiApiKey": "",
      "eas": {
        "projectId": "your-project-id"
      }
    }
  }
}