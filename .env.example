# FitTrack Environment Variables
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in your actual values
# NEVER commit environment files to version control

# ===========================================
# ENVIRONMENT
# ===========================================

# Environment type: dev, staging, or prod
APP_ENV=development

# ===========================================
# API KEYS
# ===========================================

# Google Gemini API Key (for AI food recognition)
# Get your key at: https://makersuite.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Open Food Facts API User Agent
# Format: AppName/Version (contact@email.com)
EXPO_PUBLIC_OPENFOODFACTS_USER_AGENT=FitTrack/1.0 (your@email.com)

# ===========================================
# BACKEND API (if using cloud sync)
# ===========================================

# Backend API URL
# Development: http://localhost:3000
# Staging: https://staging-api.fittrack.app
# Production: https://api.fittrack.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# ===========================================
# ANALYTICS & MONITORING (optional)
# ===========================================

# Sentry DSN for error tracking (optional)
# EXPO_PUBLIC_SENTRY_DSN=

# Analytics enabled (set to 'false' to disable)
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# ===========================================
# FEATURE FLAGS
# ===========================================

# Enable premium features (for development)
EXPO_PUBLIC_PREMIUM_ENABLED=false

# Enable debug mode
EXPO_PUBLIC_DEBUG_MODE=false
